<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.xtina.intellijthemerandomizer</id>
    <name>Theme Randomizer</name>
    <vendor>xtina</vendor>

    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>
    <extensions defaultExtensionNs="com.intellij">
        <toolWindow factoryClass="com.github.xtina.intellijthemerandomizer.toolWindow.MyToolWindowFactory" id="MyToolWindow"/>
        <postStartupActivity implementation="com.github.xtina.intellijthemerandomizer.startup.MyProjectActivity" />
        <applicationConfigurable
                id="com.github.xtina.intellijthemerandomizer.settings"
                displayName="Theme Randomizer"
                instance="com.github.xtina.intellijthemerandomizer.settings.AppSettingsConfigurable"
                groupId="appearance"/>
        <applicationService
                serviceImplementation="com.github.xtina.intellijthemerandomizer.settings.AppSettings"/>
        <applicationService
                serviceImplementation="com.github.xtina.intellijthemerandomizer.settings.ThemeGatekeeper"/>
        <applicationService
                serviceImplementation="com.github.xtina.intellijthemerandomizer.startup.ThemeSchedulerService"/>
    </extensions>

    <actions>
        <action id="ThemeRandomizer.RandomizeTheme"
                class="com.github.xtina.intellijthemerandomizer.actions.RandomizeThemeAction"
                text="Randomize Theme"
                description="Switch to a random theme from your preferred list">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
